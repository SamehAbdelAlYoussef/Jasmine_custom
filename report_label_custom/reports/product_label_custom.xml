<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="paperformat_product_label" model="report.paperformat">
        <field name="name">Xprinter Label 38x25</field>
        <field name="default" eval="False"/>
        <field name="format">custom</field>
        <field name="page_height">25</field>
        <field name="page_width">38</field>
        <field name="orientation">Portrait</field>
        <field name="margin_top">0</field>
        <field name="margin_bottom">0</field>
        <field name="margin_left">0</field>
        <field name="margin_right">0</field>
        <field name="header_line" eval="False"/>
        <field name="header_spacing">0</field>
        <field name="disable_shrinking" eval="True"/>
        <field name="dpi">203</field>
    </record>

    <record id="action_report_product_label_custom" model="ir.actions.report">
        <field name="name">Product Label Custom 38x25</field>
        <field name="model">product.product</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">report_label_custom.template_report_product_label_custom</field>
        <field name="report_file">report_label_custom/template_report_product_label_custom</field>
        <field name="paperformat_id" ref="report_label_custom.paperformat_product_label"/>
    </record>

    <template id="template_report_product_label_custom">
        <t t-call="web.html_container">
            <t t-foreach="products_data" t-as="p">
                <t t-set="is_last" t-value="p_index == len(products_data) - 1"/>
                <div t-att-style="'width:38mm; height:25mm; padding:1.5mm; box-sizing:border-box; font-family:Arial,sans-serif; text-align:center; overflow:hidden;' + ('' if is_last else ' page-break-after:always;')">

                    <t t-if="p['barcode']">
                        <div t-out="p['barcode']"
                             t-options="{
                                 'widget': 'barcode',
                                 'symbology': 'Code128',
                                 'quiet': 0,
                                 'img_style': 'width:34mm; height:8mm;',
                                 'img_class': ''
                             }"/>
                    </t>
                    <t t-else="">
                        <div style="width:34mm; height:8mm; background:#ffcccc; font-size:5px; line-height:8mm; margin:0 auto;">
                            No Barcode
                        </div>
                    </t>

                    <!-- Barcode Number -->
                    <div style="font-size:5.5px; margin-top:0.5mm; letter-spacing:0.5px;">
                        <t t-out="p['barcode']"/>
                    </div>

                    <!-- Product Name -->
                    <div style="font-size:6.5px; font-weight:bold; margin-top:0.5mm; overflow:hidden; white-space:nowrap; text-overflow:ellipsis; max-width:35mm;">
                        <t t-out="p['name']"/>
                    </div>

                </div>
            </t>
        </t>
    </template>
</odoo>