<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Contact Page -->
    <template id="beauty_shop_contact_page" inherit_id="website.contactus" name="Beauty Shop Contact Page"
              priority="100">
        <xpath expr="//div[@id='wrap']" position="replace">
            <main>
                <!-- Contact hero -->
                <section class="contact-hero" id="contact-main">
                    <div class="container">
                        <nav class="breadcrumb-nav" aria-label="breadcrumb">
                            <a href="/">Home</a>
                            <i class="bi bi-chevron-right"/>
                            <span>Contact</span>
                        </nav>
                        <div class="row align-items-end g-4">
                            <div class="col-lg-8">
                                <span class="eyebrow">— Say hello</span>
                                <h1 class="contact-title">We'd love to
                                    <em>hear from you.</em>
                                </h1>
                            </div>
                            <div class="col-lg-4 text-lg-end">
                                <p class="text-muted mb-0">Skincare questions, order help, press, partnerships — every
                                    message lands in our inbox. Average reply time: under 4 hours, Mon–Fri.
                                </p>
                            </div>
                        </div>
                    </div>
                </section>
                <!-- Contact methods -->
                <section class="contact-methods">
                    <div class="container">
                        <div class="row g-3 g-lg-4">
                            <div class="col-md-6 col-lg-3">
                                <a href="#contact-form" class="method-card">
                                    <i class="bi bi-chat-dots"/>
                                    <h6>Live chat</h6>
                                    <small>Mon–Fri · 9am–6pm PT</small>
                                    <span class="m-link">Start a chat
                                        <i class="bi bi-arrow-up-right"/>
                                    </span>
                                </a>
                            </div>
                            <div class="col-md-6 col-lg-3">
                                <a href="mailto:hello@glowing.com" class="method-card">
                                    <i class="bi bi-envelope"/>
                                    <h6>Email us</h6>
                                    <small>Replies within 4 hours</small>
                                    <span class="m-link">hello@glowing.com
                                        <i class="bi bi-arrow-up-right"/>
                                    </span>
                                </a>
                            </div>
                            <div class="col-md-6 col-lg-3">
                                <a href="tel:+14155550143" class="method-card">
                                    <i class="bi bi-telephone"/>
                                    <h6>Call us</h6>
                                    <small>Mon–Fri · 9am–5pm PT</small>
                                    <span class="m-link">+1 (415) 555-0143
                                        <i class="bi bi-arrow-up-right"/>
                                    </span>
                                </a>
                            </div>
                            <div class="col-md-6 col-lg-3">
                                <a href="#locations" class="method-card">
                                    <i class="bi bi-geo-alt"/>
                                    <h6>Visit the studio</h6>
                                    <small>Open Tue–Sat · By appointment</small>
                                    <span class="m-link">Find us
                                        <i class="bi bi-arrow-up-right"/>
                                    </span>
                                </a>
                            </div>
                        </div>
                    </div>
                </section>
                <!-- Form + Side -->
                <section class="contact-form-section" id="contact-form">
                    <div class="container">
                        <div class="row g-5 align-items-start">
                            <div class="col-lg-7">
                                <div class="cf-card">
                                    <span class="eyebrow">— Send a message</span>
                                    <h2 class="display-6 fw-light mb-2">Tell us what you're
                                        <em>looking for</em>
                                    </h2>
                                    <p class="text-muted mb-4">Every message is read by a real human — usually Sofia,
                                        sometimes Maya. We answer within one business day.
                                    </p>
                                    <form class="s_website_form cf-form"
                                          action="/website/form/"
                                          method="post"
                                          enctype="multipart/form-data"
                                          data-model_name="mail.mail"
                                          data-success-mode="redirect"
                                          data-success-page="/contact/thank-you">
                                        <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                                        <input type="hidden" name="website_form_signature"
                                               t-att-value="request.website_form_signature()"/>
                                        <div class="form-grid">
                                            <div class="field">
                                                <label for="cf-name">First name</label>
                                                <input id="cf-name" name="name" type="text" placeholder="Jane"
                                                       required="required"/>
                                            </div>
                                            <div class="field">
                                                <label for="cf-second-name">Last name</label>
                                                <!-- Merged into 'name' by the controller before super() -->
                                                <input id="cf-second-name" name="second_name" type="text"
                                                       placeholder="Doe" required="required"/>
                                            </div>
                                            <div class="field">
                                                <label for="cf-email">Email</label>
                                                <input id="cf-email" name="email_from" type="email"
                                                       placeholder="you@email.com" required="required"/>
                                            </div>
                                            <div class="field">
                                                <label for="cf-topic">What can we help with?</label>
                                                <select id="cf-topic" name="subject" required="required">
                                                    <option value="">Choose a topic…</option>
                                                    <option>Order help</option>
                                                    <option>Product question</option>
                                                    <option>Routine advice</option>
                                                    <option>Press / Partnerships</option>
                                                    <option>Wholesale</option>
                                                    <option>Something else</option>
                                                </select>
                                            </div>
                                            <div class="field">
                                                <label for="cf-order">Order #
                                                    <small>(if applicable)</small>
                                                </label>
                                                <input id="cf-order" name="order" type="text" placeholder="GW-00000"/>
                                            </div>
                                            <div class="field span-2">
                                                <label for="cf-msg">Your message</label>
                                                <textarea id="cf-msg" name="body_html" rows="5"
                                                          placeholder="Tell us what's on your mind..."
                                                          required="required"/>
                                            </div>
                                            <div class="field span-2">
                                                <label class="check-line">
                                                    <input type="checkbox" name="subscribe"/>
                                                    <span>Send me skin tips and subscriber‑only offers — no spam,
                                                        ever.
                                                    </span>
                                                </label>
                                            </div>
                                        </div>
                                        <div class="cf-actions">
                                            <button type="submit" class="btn-routine s_website_form_send">
                                                <span>Send message</span>
                                                <span class="arrow-chip">
                                                    <i class="bi bi-arrow-up-right"/>
                                                </span>
                                            </button>
                                            <small class="text-muted">By submitting you agree to our <a href="#">privacy
                                                policy</a>.
                                            </small>
                                        </div>
                                        <span id="s_website_form_result"/>
                                    </form>
                                </div>
                            </div>
                            <div class="col-lg-5">
                                <aside class="cf-aside">
                                    <div class="cf-image">
                                        <img src="/theme_beauty_shop/static/src/img/routine-ritual.jpg"
                                             alt="Our studio in San Francisco"/>
                                        <span class="cf-image-tag">
                                            <i class="bi bi-geo-alt"/>
                                            San Francisco
                                        </span>
                                    </div>
                                    <div class="cf-quick">
                                        <h6>Quick answers</h6>
                                        <ul>
                                            <li>
                                                <a href="#">
                                                    <span>How fast do you ship?</span>
                                                    <i class="bi bi-arrow-up-right"/>
                                                </a>
                                            </li>
                                            <li>
                                                <a href="#">
                                                    <span>What's your return policy?</span>
                                                    <i class="bi bi-arrow-up-right"/>
                                                </a>
                                            </li>
                                            <li>
                                                <a href="#">
                                                    <span>Where can I track my order?</span>
                                                    <i class="bi bi-arrow-up-right"/>
                                                </a>
                                            </li>
                                            <li>
                                                <a href="#">
                                                    <span>Are your products vegan?</span>
                                                    <i class="bi bi-arrow-up-right"/>
                                                </a>
                                            </li>
                                        </ul>
                                    </div>
                                    <div class="cf-press">
                                        <strong>Press &amp; partnerships</strong>
                                        <p>For media requests, sample bookings, or collaborations, write to <a
                                                href="mailto:press@glowing.com">press@glowing.com</a>.
                                        </p>
                                    </div>
                                </aside>
                            </div>
                        </div>
                    </div>
                </section>
                <!-- FAQ -->
                <section class="contact-faq">
                    <div class="container">
                        <div class="row g-5">
                            <div class="col-lg-4">
                                <span class="eyebrow">— Common questions</span>
                                <h2 class="display-5 fw-light mb-3">Before you write,
                                    <em>start here.</em>
                                </h2>
                                <p class="text-muted">Most questions land in one of these — but if yours doesn't, the
                                    form is right above.
                                </p>
                            </div>
                            <div class="col-lg-8">
                                <div class="accordion faq-accordion" id="faqAccordion">
                                    <div class="accordion-item faq-item">
                                        <h2 class="accordion-header">
                                            <button class="accordion-button" type="button" data-bs-toggle="collapse"
                                                    data-bs-target="#faq1">
                                                How long does shipping take?
                                            </button>
                                        </h2>
                                        <div id="faq1" class="accordion-collapse collapse show"
                                             data-bs-parent="#faqAccordion">
                                            <div class="accordion-body">
                                                Standard U.S. orders arrive in 3–5 business days, free over $50. Express
                                                options at checkout. International ships in 7–14 days via DHL.
                                            </div>
                                        </div>
                                    </div>
                                    <div class="accordion-item faq-item">
                                        <h2 class="accordion-header">
                                            <button class="accordion-button collapsed" type="button"
                                                    data-bs-toggle="collapse" data-bs-target="#faq2">
                                                What's your return policy?
                                            </button>
                                        </h2>
                                        <div id="faq2" class="accordion-collapse collapse"
                                             data-bs-parent="#faqAccordion">
                                            <div class="accordion-body">
                                                Try anything for 60 days. If it's not right, return for a full refund —
                                                even if the bottle's half-empty. We handle the return label.
                                            </div>
                                        </div>
                                    </div>
                                    <div class="accordion-item faq-item">
                                        <h2 class="accordion-header">
                                            <button class="accordion-button collapsed" type="button"
                                                    data-bs-toggle="collapse" data-bs-target="#faq3">
                                                Are your products vegan and cruelty-free?
                                            </button>
                                        </h2>
                                        <div id="faq3" class="accordion-collapse collapse"
                                             data-bs-parent="#faqAccordion">
                                            <div class="accordion-body">
                                                Yes to both. Leaping Bunny certified, and the entire line is vegan except for                                                 two products that use ethically sourced beeswax —
                                                clearly labeled.
                                            </div>
                                        </div>
                                    </div>
                                    <div class="accordion-item faq-item">
                                        <h2 class="accordion-header">
                                            <button class="accordion-button collapsed" type="button"
                                                    data-bs-toggle="collapse" data-bs-target="#faq4">
                                                How do refills work?
                                            </button>
                                        </h2>
                                        <div id="faq4" class="accordion-collapse collapse"
                                             data-bs-parent="#faqAccordion">
                                            <div class="accordion-body">
                                                Order the refill pouch for any primary product — same formula, 70% less
                                                packaging. Pour into your glass bottle and you're set. Subscribe to save
                                                15%.
                                            </div>
                                        </div>
                                    </div>
                                    <div class="accordion-item faq-item">
                                        <h2 class="accordion-header">
                                            <button class="accordion-button collapsed" type="button"
                                                    data-bs-toggle="collapse" data-bs-target="#faq5">
                                                Do you offer wholesale or stockist accounts?
                                            </button>
                                        </h2>
                                        <div id="faq5" class="accordion-collapse collapse"
                                             data-bs-parent="#faqAccordion">
                                            <div class="accordion-body">
                                                Yes — we partner with select boutiques and clinics. Email <a
                                                    href="mailto:wholesale@glowing.com">wholesale@glowing.com
                                            </a> with your shop details for our lookbook.
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </section>
                <!-- Newsletter -->
                <section class="newsletter">
                    <div class="container">
                        <div class="newsletter-card">
                            <span class="eyebrow">— Stay in the glow</span>
                            <h2 class="news-title">Get <em>10% off</em> your first order
                            </h2>
                            <p class="news-sub">Subscribe for early access, expert skin tips, and subscriber-only
                                offers.
                            </p>
                            <form class="news-form"
                                  onsubmit="event.preventDefault(); this.querySelector('.sub-msg').classList.add('show');">
                                <label class="news-input-group">
                                    <input type="email" placeholder="Your email address" required="required"/>
                                    <button type="submit" class="btn-routine sm news-submit">
                                        <span>Subscribe</span>
                                        <span class="arrow-chip">
                                            <i class="bi bi-arrow-up-right"/>
                                        </span>
                                    </button>
                                </label>
                                <small class="form-foot">By subscribing you agree to our <a href="#">privacy policy</a>.
                                </small>
                                <small class="sub-msg">✓ Welcome — check your inbox for your code.</small>
                            </form>
                        </div>
                    </div>
                </section>
            </main>
        </xpath>
    </template>
</odoo>
