<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Footer -->
    <template id="beauty_shop_footer" inherit_id="website.layout" name="Custom Footer">
        <xpath expr="//footer" position="replace">
            <footer class="site-footer">
                <div class="container">
                    <div class="row g-5">
                        <div class="col-lg-4">
                            <span class="brand-mark fs-2 d-inline-flex align-items-center gap-2">
                                <img src="/theme_beauty_shop/static/src/img/logo.svg" alt="" width="40"/>Glowing<span>.</span>
                            </span>
                            <p class="mt-3 footer-muted">Clean beauty, plant-powered formulas, and packaging that loves the planet as much as your skin.</p>
                            <div class="social d-flex gap-2 mt-3">
                                <a href="#" aria-label="Instagram"><i class="bi bi-instagram"/></a>
                                <a href="#" aria-label="Facebook"><i class="bi bi-facebook"/></a>
                                <a href="#" aria-label="Pinterest"><i class="bi bi-pinterest"/></a>
                                <a href="#" aria-label="TikTok"><i class="bi bi-tiktok"/></a>
                                <a href="#" aria-label="YouTube"><i class="bi bi-youtube"/></a>
                            </div>
                        </div>
                        <div class="col-6 col-md-3 col-lg-2">
                            <h6>Shop</h6>
                            <ul>
                                <li><a href="/shop">Skincare</a></li>
                                <li><a href="/shop">Haircare</a></li>
                                <li><a href="/shop">Body Care</a></li>
                                <li><a href="/shop">Fragrance</a></li>
                            </ul>
                        </div>
                        <div class="col-6 col-md-3 col-lg-2">
                            <h6>Help</h6>
                            <ul>
                                <li><a href="/contactus">Contact us</a></li>
                                <li><a href="/about">About</a></li>
                            </ul>
                        </div>
                        <div class="col-md-6 col-lg-4">
                            <h6>Visit us</h6>
                            <p class="footer-muted mb-2">122 Marigold Lane, Suite 410<br/>San Francisco, CA 94110</p>
                            <p class="footer-muted mb-0"><i class="bi bi-telephone me-2"/>+1 (415) 555-0143</p>
                            <p class="footer-muted"><i class="bi bi-envelope me-2"/>hello@glowing.com</p>
                            <div class="payment-icons">
                                <i class="bi bi-credit-card-2-front"/>
                                <i class="bi bi-paypal"/>
                                <i class="bi bi-apple"/>
                                <i class="bi bi-google"/>
                            </div>
                        </div>
                    </div>
                    <hr/>
                    <div class="d-flex flex-column flex-md-row justify-content-between align-items-center small footer-muted">
                        <span>© 2026 Glowing Co. All rights reserved.</span>
                        <div class="d-flex gap-3">
                            <a href="#">Privacy</a>
                            <a href="#">Terms</a>
                            <a href="#">Cookies</a>
                            <a href="#">Accessibility</a>
                        </div>
                    </div>
                </div>
            </footer>
        </xpath>
    </template>
</odoo>
