<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Cart page customization for Beauty Shop Theme -->
    <template id="beauty_shop_cart" inherit_id="website_sale.cart" name="Beauty Shop Cart">
        <!-- Replace the entire layout call to build the cart.html exactly -->
        <xpath expr="//t[@t-call='website_sale.checkout_layout']" position="replace">
            <t t-call="website.layout">
                <t t-set="additional_title">Shopping Cart</t>

                <div id="wrap" class="oe_website_sale js_sale">
                    <!-- Cart hero -->
                    <section class="cart-hero">
                        <div class="container">
                            <nav class="breadcrumb-nav" aria-label="breadcrumb">
                                <a href="/">Home</a>
                                <i class="bi bi-chevron-right"/>
                                <span>Shopping Cart</span>
                            </nav>
                            <div class="row align-items-end g-3">
                                <div class="col-md-8">
                                    <h1 class="cart-title">Your <em>cart</em></h1>
                                </div>
                                <div class="col-md-4 text-md-end">
                                    <span class="cart-count"><strong><t t-out="website_sale_order.cart_quantity"/> items</strong> in your bag</span>
                                </div>
                            </div>
                            <!-- Progress steps -->
                            <ol class="cart-steps">
                                <li class="active">
                                    <span class="step-circle">1</span>
                                    <div><strong>Cart</strong><small>Review items</small></div>
                                </li>
                                <li>
                                    <span class="step-circle">2</span>
                                    <div><strong>Shipping</strong><small>Where to deliver</small></div>
                                </li>
                                <li>
                                    <span class="step-circle">3</span>
                                    <div><strong>Payment</strong><small>Secure checkout</small></div>
                                </li>
                                <li>
                                    <span class="step-circle"><i class="bi bi-check"/></span>
                                    <div><strong>Done</strong><small>Order confirmed</small></div>
                                </li>
                            </ol>
                        </div>
                    </section>
                    <!-- Cart main -->
                    <section class="cart-main" id="cart-main">
                        <div class="container">
                            <div class="row g-4 g-lg-5">
                                <!-- Items -->
                                <div class="col-lg-8 cart-items-col oe_cart" id="shop_cart">
                                    <!-- Required by Odoo JS for reorder sidebar (do not remove) -->
                                    <div style="display:none">
                                        <t t-call="website_sale.quick_reorder_button"/>
                                    </div>
                                    <!-- Free shipping progress placeholder -->
                                    <div class="ship-progress">
                                        <div class="sp-text">
                                            <i class="bi bi-truck"/>
                                            <span>You're <strong>$6.00</strong> away from free shipping!</span>
                                        </div>
                                        <div class="sp-bar"><span style="width: 88%"/></div>
                                    </div>
                                    <t t-call="website_sale.cart_lines"/>
                                    <!-- Cart footer actions -->
                                    <div class="cart-foot">
                                        <a href="/shop" class="continue-link"><i class="bi bi-arrow-left"/> Continue shopping</a>
                                        <a href="/beauty/cart/clear" class="btn btn-link clear-cart text-muted"><i class="bi bi-trash"/> Clear cart</a>
                                    </div>
                                    <!-- Gift wrap toggle -->
                                    <div class="addon-card mt-4">
                                        <label class="addon-toggle">
                                            <input type="checkbox"/>
                                            <span class="addon-box">
                                                <i class="bi bi-gift"/>
                                                <div>
                                                    <strong>Add gift wrapping</strong>
                                                    <small>Recycled kraft box, ribbon &amp; handwritten note · $5.00</small>
                                                </div>
                                            </span>
                                        </label>
                                    </div>
                                    <div class="oe_structure" id="oe_structure_website_sale_cart_1"/>
                                </div>
                                <!-- Summary sidebar -->
                                <aside class="col-lg-4">
                                    <div class="cart-summary" id="o_cart_summary">
                                        <h3 class="summary-title">Order summary</h3>
                                        <!-- Promo code form using Odoo's native component -->
                                        <div class="promo-row mb-3">
                                            <t t-call="website_sale.coupon_form"/>
                                        </div>
                                        <!-- Totals -->
                                        <t t-call="website_sale.total"/>
                                        <!-- Checkout button -->
                                        <a href="/shop/checkout?express=1" class="btn-routine cart-checkout w-100 mt-4 d-flex justify-content-center align-items-center text-center text-decoration-none">
                                            <span>Secure Checkout</span>
                                            <span class="arrow-chip ms-2"><i class="bi bi-arrow-up-right"/></span>
                                        </a>
                                        <!-- Trust info -->
                                        <ul class="summary-trust mt-4">
                                            <li><i class="bi bi-shield-lock"/> 256-bit SSL secure checkout</li>
                                            <li><i class="bi bi-arrow-repeat"/> 30-day hassle-free returns</li>
                                            <li><i class="bi bi-truck"/> Tracked shipping on every order</li>
                                        </ul>
                                        <!-- Payment methods -->
                                        <div class="pay-row mt-3">
                                            <small>We accept</small>
                                            <div class="pay-icons">
                                                <span title="Visa"><i class="bi bi-credit-card-2-front"/></span>
                                                <span title="Mastercard"><i class="bi bi-credit-card"/></span>
                                                <span title="PayPal"><i class="bi bi-paypal"/></span>
                                                <span title="Apple Pay"><i class="bi bi-apple"/></span>
                                                <span title="Google Pay"><i class="bi bi-google"/></span>
                                            </div>
                                        </div>
                                    </div>
                                    <!-- Have a question card -->
                                    <div class="help-card mt-4">
                                        <i class="bi bi-headset"/>
                                        <div>
                                            <strong>Need help with your order?</strong>
                                            <small>Chat with us 9am–6pm PT · <a href="mailto:hello@glowing.com">hello@glowing.com</a></small>
                                        </div>
                                    </div>
                                </aside>
                            </div>
                        </div>
                    </section>
                    <!-- Recommendations -->
                    <section class="cart-related">
                        <div class="container">
                            <div class="d-flex justify-content-between align-items-end mb-4">
                                <div>
                                    <span class="eyebrow">— Customers also bought</span>
                                    <h2 class="rel-title">Complete your <em>routine</em></h2>
                                </div>
                                <a href="/shop" class="btn-routine sm d-none d-md-inline-flex">
                                    <span>Shop all</span>
                                    <span class="arrow-chip"><i class="bi bi-arrow-up-right"/></span>
                                </a>
                            </div>
                            <div class="row g-3 g-md-4" id="products_grid">
                                <t t-set="routine_products" t-value="request.env['product.template'].search([('website_published', '=', True)], limit=4)"/>
                                <t t-foreach="routine_products" t-as="r_product">
                                    <div class="col-6 col-md-3">
                                        <article class="product-card">
                                            <div class="product-media tone-mint">
                                                <t t-set="in_wish" t-value="r_product._is_in_wishlist()"/>
                                                <button t-attf-class="wish-btn o_add_wishlist #{in_wish and 'disabled'}" t-att-disabled="in_wish" t-att-data-product-product-id="r_product.product_variant_ids[0].id" t-att-data-product-template-id="r_product.id" aria-label="Wishlist"><i t-attf-class="bi #{in_wish and 'bi-heart-fill text-danger' or 'bi-heart'}"/></button>
                                                <a t-att-href="'/shop/product/%s' % slug(r_product)">
                                                    <span t-field="r_product.image_1920" t-options="{'widget': 'image', 'class': 'product-img'}" />
                                                </a>
                                                <button type="submit" class="quick-add"><i class="bi bi-bag-plus me-2"/>Add to Cart</button>
                                            </div>
                                            <div class="product-body">
                                                <div class="d-flex justify-content-between align-items-center mb-1">
                                                    <small class="cat-label"><t t-out="r_product.public_categ_ids[0].name if r_product.public_categ_ids else 'Shop'"/></small>
                                                </div>
                                                <h3 class="product-title"><a t-att-href="'/shop/product/%s' % slug(r_product)"><t t-out="r_product.name"/></a></h3>
                                                <div class="price">
                                                    <t t-set="combination_info" t-value="r_product._get_combination_info()"/>
                                                    <span t-out="combination_info['price']" t-options="{'widget': 'monetary', 'display_currency': website.currency_id}"/>
                                                </div>
                                            </div>
                                        </article>
                                    </div>
                                </t>
                            </div>
                        </div>
                    </section>
                    <div class="oe_structure" id="oe_structure_website_sale_cart_2"/>
                </div>
            </t>
        </xpath>
    </template>
    <!-- Override Cart Lines to keep design during AJAX updates -->
    <template id="beauty_shop_cart_lines" inherit_id="website_sale.cart_lines" name="Beauty Shop Cart Lines">
        <xpath expr="//div[hasclass('js_cart_lines') and @id='cart_products']" position="replace">
            <div class="cart-items js_cart_lines" id="cart_products" t-if="website_sale_order and website_sale_order.website_order_line">
                <t t-foreach="website_sale_order.website_order_line" t-as="line">
                    <article class="cart-item o_cart_product" t-att-data-product-id="line.product_id.id">
                        <a t-attf-href="/shop/product/#{slug(line.product_id.product_tmpl_id)}" class="ci-image">
                            <span t-field="line.product_id.image_128" t-options="{'widget': 'image'}" />
                        </a>
                        <div class="ci-details">
                            <small class="ci-cat" t-if="line.product_id.public_categ_ids"><t t-out="line.product_id.public_categ_ids[0].name"/></small>
                            <h3 class="ci-title"><a t-attf-href="/shop/product/#{slug(line.product_id.product_tmpl_id)}"><t t-out="line.name_short"/></a></h3>
                            <ul class="ci-variants">
                                <t t-if="line._get_combination_name()">
                                    <li><span>Variant:</span> <t t-out="line._get_combination_name()"/></li>
                                </t>
                                <li><span>SKU:</span> <t t-out="line.product_id.default_code or 'N/A'"/></li>
                            </ul>
                            <div class="ci-actions">
                                <button class="ci-link"><i class="bi bi-heart"/> Save for later</button>
                                <a href="#" class="ci-link js_delete_product" aria-label="Remove from cart" title="Remove from cart"><i class="bi bi-trash"/> Remove</a>
                            </div>
                        </div>
                        <div class="ci-end">
                            <div class="ci-qty css_quantity input-group">
                                <a href="#" class="btn btn-link px-2 js_add_cart_json css_quantity_minus" aria-label="Decrease">
                                    <i class="oi oi-minus d-none"/>
                                    <i class="bi bi-dash"/>
                                </a>
                                <input type="text" class="js_quantity quantity form-control text-center border-0 bg-transparent" style="width: 50px; outline: none; box-shadow: none;" t-att-data-line-id="line.id" t-att-data-product-id="line.product_id.id" t-att-value="int(line.product_uom_qty)"/>
                                <a href="#" class="btn btn-link px-2 js_add_cart_json css_quantity_plus" aria-label="Increase">
                                    <i class="oi oi-plus d-none"/>
                                    <i class="bi bi-plus"/>
                                </a>
                            </div>
                            <div class="ci-price">
                                <strong>
                                    <span t-field="line.price_reduce_taxexcl" t-options="{'widget': 'monetary', 'display_currency': website_sale_order.currency_id}"/>
                                </strong>
                                <small>per item</small>
                            </div>
                        </div>
                    </article>
                </t>
            </div>
        </xpath>
        <xpath expr="//div[hasclass('js_cart_lines') and not(@id='cart_products')]" position="replace">
            <div t-if="not website_sale_order or not website_sale_order.website_order_line" class="js_cart_lines py-5 text-center w-100">
                <h4 class="mb-3">Your cart is empty!</h4>
                <p><a href="/shop" class="btn btn-primary">Continue Shopping</a></p>
            </div>
        </xpath>
    </template>
</odoo>