<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <!-- Header Template -->
    <template id="theme_beauty_shop_header" inherit_id="website.layout" active="True">
        <xpath expr="//header" position="replace">
            <div class="oe_structure"/>
            <header class="bs_navigation" id="top">
                <div class="bs_header_wrapper">
                    <div class="container">
                        <nav class="navbar navbar-expand-lg w-100 py-0">
                            <div class="container-fluid px-0">
                                <!-- Logo -->
                                <a class="navbar-brand bs_logo me-4" href="/">
                                    <img src="/theme_beauty_shop/static/src/img/logo.svg"
                                         alt="Your Logo"/>
                                </a>
                                <h4 style="padding-right: 100px; padding-top: 5px;">Glowing .</h4>
                                <!-- Mobile Toggle -->
                                <button class="navbar-toggler border-0" type="button"
                                        data-bs-toggle="collapse"
                                        data-bs-target="#bsNavbarContent"
                                        aria-controls="bsNavbarContent"
                                        aria-expanded="false"
                                        aria-label="Toggle navigation">
                                    <i class="bi bi-list"/>
                                </button>
                                <!-- Nav Links (left-aligned, next to logo) -->
                                <div class="collapse navbar-collapse" id="bsNavbarContent">
                                    <ul class="nav navbar-nav top_menu me-auto" id="top_menu">
                                        <t t-foreach="website.menu_id.child_id" t-as="submenu">
                                            <t t-call="website.submenu">
                                                <t t-set="item_class" t-value="'nav-item'"/>
                                                <t t-set="link_class" t-value="'nav-link bs_nav_link'"/>
                                            </t>
                                        </t>
                                    </ul>
                                    <!-- Right-side Icons & Actions -->
                                    <div class="bs_nav_right d-flex align-items-center gap-2">
                                        <!-- Cart -->
                                        <t t-call="website_sale.header_cart_link">
                                            <t t-set="_icon" t-value="True"/>
                                            <t t-set="_item_class" t-value="'nav-item'"/>
                                            <t t-set="_link_class"
                                               t-value="'nav-link bs_icon_btn position-relative p-1 rounded-circle'"/>
                                            <t t-set="_badge_class"
                                               t-value="'position-absolute top-0 end-0 rounded-pill mt-n1 me-n1 bs_badge'"/>
                                        </t>
                                        <!-- Wishlist -->
                                        <t t-call="website_sale_wishlist.header_wishlist_link">
                                            <t t-set="_icon" t-value="True"/>
                                            <t t-set="_item_class" t-value="'nav-item'"/>
                                            <t t-set="_link_class"
                                               t-value="'nav-link bs_icon_btn position-relative p-1 rounded-circle'"/>
                                            <t t-set="_badge_class"
                                               t-value="'position-absolute top-0 end-0 rounded-pill mt-n1 me-n1 bs_badge'"/>
                                        </t>
                                        <!-- Search -->
                                        <t t-call="website.placeholder_header_search_box">
                                            <t t-set="_layout" t-valuef="modal"/>
                                            <t t-set="_input_classes"
                                               t-valuef="border border-end-0 p-3"/>
                                            <t t-set="_submit_classes"
                                               t-valuef="border border-start-0 px-4"/>
                                            <t t-set="_button_classes"
                                               t-valuef="bs_icon_btn text-reset"/>
                                        </t>
                                        <!-- Phone Number -->
                                        <div class="bs_phone d-none d-lg-flex align-items-center gap-1">
                                            <i class="bi bi-telephone-fill bs_phone_icon"/>
                                            <span class="bs_phone_text">+1 555-555-5556</span>
                                        </div>
                                        <!-- User Dropdown -->
                                        <t t-call="portal.placeholder_user_sign_in">
                                            <t t-set="_link_class"
                                               t-valuef="btn bs_btn_outline d-none d-lg-inline-flex"/>
                                        </t>
                                        <t t-call="portal.user_dropdown">
                                            <t t-set="_user_name" t-value="True"/>
                                            <t t-set="_item_class" t-valuef="dropdown"/>
                                            <t t-set="_link_class"
                                               t-valuef="btn bs_btn_outline border-0 fw-semibold d-none d-lg-inline-flex"/>
                                            <t t-set="_user_name_class" t-valuef="small"/>
                                            <t t-set="_dropdown_menu_class"
                                               t-valuef="dropdown-menu-end"/>
                                        </t>
                                        <!-- Contact Us CTA Button -->
                                        <a href="/contactus"
                                           class="btn bs_btn_cta d-none d-lg-inline-block">
                                            Contact Us
                                        </a>
                                    </div>
                                </div>
                            </div>
                        </nav>
                    </div>
                </div>
            </header>
        </xpath>
    </template>
</odoo>
