<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- About page template for Beauty Shop Theme -->
    <template id="beauty_shop_about_page" name="About Page">
        <!-- Replace the main layout call with the custom About page markup -->
        <t t-call="website.layout">
            <t t-set="additional_title">About</t>
            <!-- Insert the full HTML content from about.html -->
            <div class="site-wrapper">
                <!-- Begin About page content -->
                <section class="about-hero" id="about-main">
                    <div class="container">
                        <nav class="breadcrumb-nav" aria-label="breadcrumb">
                            <a href="/">Home</a>
                            <i class="bi bi-chevron-right"/>
                            <span>About</span>
                        </nav>
                        <div class="row align-items-end g-4">
                            <div class="col-lg-8">
                                <span class="eyebrow">— Our story</span>
                                <h1 class="about-title">Honest beauty,
                                    <em>made for everyone.</em>
                                </h1>
                            </div>
                            <div class="col-lg-4 text-lg-end">
                                <p class="text-muted mb-0">Founded in 2018 in San Francisco, Glowing was born from a
                                    simple idea: skincare should feel as good as it works — without compromise.
                                </p>
                            </div>
                        </div>
                    </div>
                </section>
                <section class="about-story">
                    <div class="container">
                        <div class="row g-5 align-items-center">
                            <div class="col-lg-6">
                                <div class="story-collage">
                                    <div class="sc-tile sc-1">
                                        <img src="/theme_beauty_shop/static/src/img/routine-ritual.jpg"
                                             alt="Founders building a daily ritual"/>
                                    </div>
                                    <div class="sc-tile sc-2">
                                        <img src="/theme_beauty_shop/static/src/img/hero-oil.jpg"
                                             alt="Plant-powered formulas"/>
                                    </div>
                                    <div class="sc-tile sc-3">
                                        <img src="/theme_beauty_shop/static/src/img/product-serum.jpg"
                                             alt="Lab-tested products"/>
                                        <span class="sc-badge">
                                            <i class="bi bi-flower2"/>
                                            Plant-powered
                                        </span>
                                    </div>
                                </div>
                            </div>
                            <div class="col-lg-6">
                                <span class="eyebrow">— Made with care</span>
                                <h2 class="display-5 fw-light mb-3">A small studio with
                                    <em>big standards</em>
                                </h2>
                                <p class="lead-muted">We started Glowing after years of reading labels we couldn't
                                    pronounce. Today we formulate every product around a single question: would we use
                                    this on our own skin, every day?
                                </p>
                                <ul class="story-list">
                                    <li>
                                        <i class="bi bi-check2-circle"/>
                                        1,800+ ingredients on our "no" list — every formula screened
                                    </li>
                                    <li>
                                        <i class="bi bi-check2-circle"/>
                                        Independently dermatologist tested for every skin type
                                    </li>
                                    <li>
                                        <i class="bi bi-check2-circle"/>
                                        Refillable glass packaging — built to live more than once
                                    </li>
                                </ul>
                                <a href="/shop" class="btn-routine mt-2">
                                    <span>Shop our edit</span>
                                    <span class="arrow-chip">
                                        <i class="bi bi-arrow-up-right"/>
                                    </span>
                                </a>
                            </div>
                        </div>
                    </div>
                </section>
                <!-- Additional sections (stats, values, timeline, team, press, CTA, newsletter, footer) are included via the original about.html layout -->
                <!-- For brevity, the remaining markup from about.html is inserted here using a raw inclusion -->
                <section class="about-stats">
                    <div class="container">
                        <div class="row g-4">
                            <div class="col-6 col-md-3">
                                <div class="stat-item">
                                    <strong>120k+</strong>
                                    <small>Happy customers worldwide</small>
                                </div>
                            </div>
                            <div class="col-6 col-md-3">
                                <div class="stat-item">
                                    <strong>4.9
                                        <span>/5</span>
                                    </strong>
                                    <small>Avg. rating · 4,200+ reviews</small>
                                </div>
                            </div>
                            <div class="col-6 col-md-3">
                                <div class="stat-item">
                                    <strong>1,800
                                        <span>+</span>
                                    </strong>
                                    <small>Ingredients on our "no" list</small>
                                </div>
                            </div>
                            <div class="col-6 col-md-3">
                                <div class="stat-item">
                                    <strong>92%</strong>
                                    <small>Of packaging is refillable</small>
                                </div>
                            </div>
                        </div>
                    </div>
                </section>
                <section class="about-values">
                    <div class="container">
                        <div class="row align-items-end mb-5">
                            <div class="col-lg-7">
                                <span class="eyebrow">— What we believe</span>
                                <h2 class="display-5 fw-light mb-0">Four promises behind
                                    <em>every bottle</em>
                                </h2>
                            </div>
                            <div class="col-lg-5 text-lg-end mt-3 mt-lg-0">
                                <p class="text-muted mb-0">These aren't talking points — they're the filters every
                                    formula has to pass before it reaches your shelf.
                                </p>
                            </div>
                        </div>
                        <div class="row g-4">
                            <div class="col-md-6 col-lg-3">
                                <div class="value-card">
                                    <span class="vc-num">01</span>
                                    <i class="bi bi-flower2"/>
                                    <h6>Plant-Powered</h6>
                                    <p>Botanical extracts at the heart of every formula — actives backed by tradition
                                        and science.
                                    </p>
                                </div>
                            </div>
                            <div class="col-md-6 col-lg-3">
                                <div class="value-card">
                                    <span class="vc-num">02</span>
                                    <i class="bi bi-shield-check"/>
                                    <h6>Clinically Tested</h6>
                                    <p>Independently dermatologist-tested for sensitivity, efficacy, and every skin
                                        type.
                                    </p>
                                </div>
                            </div>
                            <div class="col-md-6 col-lg-3">
                                <div class="value-card">
                                    <span class="vc-num">03</span>
                                    <i class="bi bi-recycle"/>
                                    <h6>Refillable Design</h6>
                                    <p>Heavy glass primaries, refill pouches — packaging built to live more than once.
                                    </p>
                                </div>
                            </div>
                            <div class="col-md-6 col-lg-3">
                                <div class="value-card">
                                    <span class="vc-num">04</span>
                                    <i class="bi bi-heart"/>
                                    <h6>Cruelty-Free</h6>
                                    <p>Never tested on animals. Leaping Bunny certified, vegan-friendly across the
                                        line.
                                    </p>
                                </div>
                            </div>
                        </div>
                    </div>
                </section>
                <section class="about-timeline">
                    <div class="container">
                        <div class="text-center mb-5">
                            <span class="eyebrow">— The journey</span>
                            <h2 class="display-5 fw-light mb-0">From kitchen table to
                                <em>120k bathrooms</em>
                            </h2>
                        </div>
                        <ol class="timeline">
                            <li>
                                <span class="tl-year">2018</span>
                                <div class="tl-body">
                                    <h6>The first batch</h6>
                                    <p>Founders Maya and Jules formulate the first Perfecting Facial Oil in a 400 sq ft
                                        studio in the Mission, San Francisco.
                                    </p>
                                </div>
                            </li>
                            <li>
                                <span class="tl-year">2020</span>
                                <div class="tl-body">
                                    <h6>The "no" list</h6>
                                    <p>We publish our 1,800+ ingredient exclusion list — long before "clean beauty"
                                        became a marketing line.
                                    </p>
                                </div>
                            </li>
                            <li>
                                <span class="tl-year">2022</span>
                                <div class="tl-body">
                                    <h6>Refill program launches</h6>
                                    <p>Heavy glass primaries, lightweight refill pouches. Customers return for years,
                                        not weeks.
                                    </p>
                                </div>
                            </li>
                            <li>
                                <span class="tl-year">2024</span>
                                <div class="tl-body">
                                    <h6>Leaping Bunny certified</h6>
                                    <p>Cruelty-free certification confirmed across every supplier, every ingredient,
                                        every step.
                                    </p>
                                </div>
                            </li>
                            <li>
                                <span class="tl-year">2026</span>
                                <div class="tl-body">
                                    <h6>Today</h6>
                                    <p>120k+ customers across 32 countries — still small enough to read every review,
                                        still answering the same question.
                                    </p>
                                </div>
                            </li>
                        </ol>
                    </div>
                </section>
                <section class="about-team">
                    <div class="container">
                        <div class="row align-items-end mb-5">
                            <div class="col-lg-8">
                                <span class="eyebrow">— The people</span>
                                <h2 class="display-5 fw-light mb-0">A small team,
                                    <em>obsessed with the details</em>
                                </h2>
                            </div>
                            <div class="col-lg-4 text-lg-end mt-3 mt-lg-0">
                                <p class="text-muted mb-0">Chemists, designers, and skincare nerds — 14 of us, all in
                                    one studio.
                                </p>
                            </div>
                        </div>
                        <div class="row g-4">
                            <div class="col-6 col-md-3">
                                <article class="team-card">
                                    <div class="team-photo">
                                        <img src="https://images.unsplash.com/photo-1494790108377-be9c29b29330?w=600&amp;h=750&amp;fit=crop&amp;crop=faces"
                                             alt="Maya Lin, co-founder"/>
                                    </div>
                                    <h6>Maya Lin</h6>
                                    <small>Co-founder &amp; CEO</small>
                                </article>
                            </div>
                            <div class="col-6 col-md-3">
                                <article class="team-card">
                                    <div class="team-photo">
                                        <img src="https://images.unsplash.com/photo-1573496359142-b8d87734a5a2?w=600&amp;h=750&amp;fit=crop&amp;crop=faces"
                                             alt="Jules Okafor, co-founder"/>
                                    </div>
                                    <h6>Jules Okafor</h6>
                                    <small>Co-founder &amp; Head of Formulation</small>
                                </article>
                            </div>
                            <div class="col-6 col-md-3">
                                <article class="team-card">
                                    <div class="team-photo">
                                        <img src="https://images.unsplash.com/photo-1487412720507-e7ab37603c6f?w=600&amp;h=750&amp;fit=crop&amp;crop=faces"
                                             alt="Sofia Reyes, head of community"/>
                                    </div>
                                    <h6>Sofia Reyes</h6>
                                    <small>Head of Community</small>
                                </article>
                            </div>
                            <div class="col-6 col-md-3">
                                <article class="team-card">
                                    <div class="team-photo">
                                        <img src="https://images.unsplash.com/photo-1500648767791-00dcc994a43e?w=600&amp;h=750&amp;fit=crop&amp;crop=faces"
                                             alt="Theo Park, design director"/>
                                    </div>
                                    <h6>Theo Park</h6>
                                    <small>Design Director</small>
                                </article>
                            </div>
                        </div>
                    </div>
                </section>
                <section class="about-press">
                    <div class="container">
                        <div class="text-center mb-4">
                            <span class="eyebrow">— As featured in</span>
                        </div>
                        <ul class="press-logos">
                            <li>VOGUE</li>
                            <li>Allure</li>
                            <li>Byrdie</li>
                            <li>Refinery29</li>
                            <li>Goop</li>
                            <li>Cosmopolitan</li>
                        </ul>
                    </div>
                </section>

                <section class="about-cta">
                    <div class="container">
                        <div class="cta-banner">
                            <div>
                                <span class="eyebrow light">— Try us on</span>
                                <h2>Find your routine in
                                    <em>under three minutes</em>
                                </h2>
                                <p>Answer five questions, and we'll build a routine around your skin — no quiz fatigue,
                                    no upsell.
                                </p>
                            </div>
                            <a href="/shop" class="btn-routine light">
                                <span>Build your routine</span>
                                <span class="arrow-chip">
                                    <i class="bi bi-arrow-up-right"/>
                                </span>
                            </a>
                        </div>
                    </div>
                </section>
                <section class="newsletter">
                    <div class="container">
                        <div class="newsletter-card">
                            <span class="eyebrow">— Stay in the glow</span>
                            <h2 class="news-title">Get <em>10% off</em> your first order
                            </h2>
                            <p>Subscribe for early access, expert skin tips, and subscriber-only offers.</p>
                            <form class="news-form"
                                  onsubmit="event.preventDefault(); this.querySelector('.sub-msg').classList.add('show');">
                                <label class="news-input-group">
                                    <input type="email" placeholder="Your email address" required="required"/>
                                    <button type="submit" class="btn-routine sm news-submit">
                                        <span>Subscribe</span>
                                        <span class="arrow-chip">
                                            <i class="bi bi-arrow-up-right"/>
                                        </span>
                                    </button>
                                </label>
                                <small class="form-foot">By subscribing you agree to our <a href="#">privacy policy</a>.
                                </small>
                                <small class="sub-msg">✓ Welcome — check your inbox for your code.</small>
                            </form>
                        </div>
                    </div>
                </section>
                <button class="back-to-top" id="backToTop" aria-label="Back to top">
                    <i class="bi bi-arrow-up"/>
                </button>
                <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"/>
            </div>
        </t>
    </template>
</odoo>
