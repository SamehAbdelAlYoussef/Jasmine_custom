<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="res_config_settings_view_form_inherit" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.inherit.shopify</field>
        <field name="model">res.config.settings</field>
        <field name="priority" eval="20"/>
        <field name="inherit_id" ref="base.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//form" position="inside">
                <app string="Shopify" data-string="Shopify" name="shopify_odoo_integration">
                    <block title="API Connection" name="shopify_api_settings">
                        <setting
                            id="shopify_shop_url_setting"
                            string="Shopify Shop URL"
                            help="Your Shopify store domain (e.g. mystore.myshopify.com)"
                            title="The base URL of your Shopify store, used to build API endpoints."
                        >
                            <field name="shopify_shop_url" placeholder="mystore.myshopify.com"/>
                        </setting>
                        <setting
                            id="shopify_access_token_setting"
                            string="Access Token"
                            help="Shopify Admin API access token for authentication"
                            title="Generate from Shopify Admin → Settings → Apps and sales channels → Develop apps."
                        >
                            <field name="shopify_access_token" placeholder="shpat_..." password="True"/>
                        </setting>
                        <setting
                            id="shopify_api_version_setting"
                            string="API Version"
                            help="Shopify REST Admin API version (e.g. 2024-10, 2025-01)"
                            title="The API version determines which Shopify API features are available."
                        >
                            <field name="shopify_api_version" placeholder="2024-10"/>
                        </setting>
                        <div class="mt-3 text-center">
                            <button
                                name="action_sync_orders_from_settings"
                                string="Sync Orders Now"
                                type="object"
                                class="btn btn-primary me-2"
                            />
                            <button
                                name="action_test_shopify_connection"
                                string="Test Connection"
                                type="object"
                                class="btn btn-secondary"
                            />
                        </div>
                    </block>

                    <block title="Inventory Sync" name="shopify_inventory_settings">
                        <setting
                            id="shopify_stock_sync_enabled_setting"
                            string="Enable Stock Sync"
                            help="Automatically push Odoo stock changes to Shopify inventory levels."
                            title="When enabled, any change to a product's available quantity triggers an update to Shopify via the inventory_levels/set.json API."
                        >
                            <field name="shopify_stock_sync_enabled"/>
                        </setting>
                        <setting
                            id="shopify_location_id_setting"
                            string="Shopify Location ID"
                            help="The fulfilment location where inventory is synced (numeric ID)."
                            title="Find this in Shopify Admin → Settings → Locations, or use the Fetch button below."
                        >
                            <field name="shopify_location_id" placeholder="e.g. 655441491"/>
                        </setting>
                        <div class="mb-3">
                            <button
                                name="action_fetch_shopify_locations"
                                string="Fetch Locations from Shopify"
                                type="object"
                                class="btn btn-secondary me-2"
                                help="Uses your API credentials to list all active Shopify locations and their IDs."
                            />
                        </div>
                        <div class="mt-3 text-center">
                            <button
                                name="action_full_inventory_sync"
                                string="Sync All Inventory to Shopify"
                                type="object"
                                class="btn btn-primary"
                                confirm="This will fetch ALL Shopify products and overwrite their inventory to match Odoo stock. This may take several minutes for large catalogs. Continue?"
                                help="Matches every Shopify variant by SKU, creates bindings, and sets Shopify inventory = Odoo qty_available. One-time bulk operation."
                            />
                        </div>
                        <setting
                            id="shopify_default_requires_shipping_setting"
                            string="Default: Requires Shipping"
                            help="Default value for new product bindings. When off, the product is treated as digital (no shipping charged)."
                            title="Synced to Shopify InventoryItem.requires_shipping."
                        >
                            <field name="shopify_default_requires_shipping"/>
                        </setting>
                    </block>
                </app>
            </xpath>
        </field>
    </record>
</odoo>
