<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Shopify Sync Form -->
    <record id="view_shopify_sync_form" model="ir.ui.view">
        <field name="name">shopify.sync.form</field>
        <field name="model">shopify.sync</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="Sync Job Name"/>
                        </h1>
                    </div>

                    <group string="Sync Progress" colspan="2">
                        <group>
                            <field name="sync_state" widget="badge"
                                   decoration-success="sync_state == 'completed'"
                                   decoration-warning="sync_state in ('fetching', 'completed_with_errors')"
                                   decoration-danger="sync_state == 'failed'"/>
                            <field name="orders_processed" string="Orders Processed"/>
                            <field name="orders_total" string="Orders Fetched"/>
                            <field name="orders_failed" string="Orders Failed"
                                   invisible="not orders_failed"/>
                        </group>
                        <group>
                            <field name="last_sync_id"/>
                            <field name="last_sync_count"/>
                            <field name="locked_until"
                                   invisible="not locked_until"/>
                            <field name="last_error"
                                   invisible="not last_error"
                                   colspan="2"/>
                        </group>
                    </group>

                    <footer>
                        <button name="action_test_connection"
                                string="Test Connection"
                                type="object"
                                class="btn-secondary"/>
                        <button name="action_sync_orders_async"
                                string="Start Sync (Background)"
                                type="object"
                                class="btn-primary"
                                invisible="sync_state == 'fetching'"/>
                        <button name="sync_orders"
                                string="Sync Now (Blocking)"
                                type="object"
                                class="btn-primary"
                                invisible="sync_state == 'fetching'"
                                confirm="This will fetch and process all orders synchronously. Continue?"/>
                    </footer>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Shopify Sync List -->
    <record id="view_shopify_sync_tree" model="ir.ui.view">
        <field name="name">shopify.sync.tree</field>
        <field name="model">shopify.sync</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="sync_state" widget="badge"
                       decoration-success="sync_state == 'completed'"
                       decoration-warning="sync_state in ('fetching', 'completed_with_errors')"
                       decoration-danger="sync_state == 'failed'"/>
                <field name="orders_processed" string="Processed"/>
                <field name="orders_total" string="Fetched"/>
                <field name="orders_failed" string="Failed"/>
                <field name="last_sync_id"/>
            </list>
        </field>
    </record>

    <!-- Shopify Sync Action -->
    <record id="action_shopify_sync" model="ir.actions.act_window">
        <field name="name">Shopify Sync</field>
        <field name="res_model">shopify.sync</field>
        <field name="view_mode">list,form</field>
        <field name="target">current</field>
    </record>

    <menuitem
        id="menu_shopify_sync"
        name="Shopify Sync"
        parent="sale.menu_sales_config"
        action="action_shopify_sync"
        sequence="31"/>

</odoo>
