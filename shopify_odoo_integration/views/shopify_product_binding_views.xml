<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ══════════════════════════════════════════════════════════════════
         Product form: add Shopify binding tab
         ════════════════════════════════════════════════════════════════ -->
    <record id="product_product_form_shopify" model="ir.ui.view">
        <field name="name">product.product.form.shopify</field>
        <field name="model">product.product</field>
        <field name="inherit_id" ref="product.product_normal_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//page[last()]" position="after">
                <page string="Shopify" name="shopify_binding">
                    <group string="Shopify Binding" name="shopify_group">
                        <field name="shopify_binding_ids" nolabel="1"/>
                    </group>
                </page>
            </xpath>
        </field>
    </record>

    <!-- ══════════════════════════════════════════════════════════════════
         Shopify Product Binding tree & action
         ════════════════════════════════════════════════════════════════ -->
    <record id="shopify_product_binding_tree" model="ir.ui.view">
        <field name="name">shopify.product.binding.tree</field>
        <field name="model">shopify.product.binding</field>
        <field name="arch" type="xml">
            <list>
                <field name="product_id"/>
                <field name="shopify_variant_id"/>
                <field name="shopify_inventory_item_id"/>
                <field name="requires_shipping"/>
                <field name="sync_inventory"/>
                <field name="last_synced_qty"/>
                <field name="last_sync_date"/>
            </list>
        </field>
    </record>

    <record id="shopify_product_binding_form" model="ir.ui.view">
        <field name="name">shopify.product.binding.form</field>
        <field name="model">shopify.product.binding</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group>
                            <field name="product_id"/>
                            <field name="shopify_product_id"/>
                            <field name="shopify_variant_id"/>
                            <field name="shopify_inventory_item_id"/>
                            <field name="shopify_location_id"/>
                        </group>
                        <group>
                            <field name="requires_shipping"/>
                            <field name="sync_inventory"/>
                            <field name="last_synced_qty"/>
                            <field name="last_sync_date"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_shopify_product_binding" model="ir.actions.act_window">
        <field name="name">Shopify Product Bindings</field>
        <field name="res_model">shopify.product.binding</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem
        id="menu_shopify_product_binding"
        name="Product Bindings"
        action="action_shopify_product_binding"
        parent="stock.menu_stock_inventory_control"
        sequence="50"
    />

    <!-- ══════════════════════════════════════════════════════════════════
         Shopify Stock Queue tree & action
         ════════════════════════════════════════════════════════════════ -->
    <record id="shopify_stock_queue_tree" model="ir.ui.view">
        <field name="name">shopify.stock.queue.tree</field>
        <field name="model">shopify.stock.queue</field>
        <field name="arch" type="xml">
            <list>
                <field name="create_date"/>
                <field name="product_id"/>
                <field name="binding_id"/>
                <field name="new_quantity"/>
                <field name="state"/>
                <field name="error_message"/>
            </list>
        </field>
    </record>

    <record id="shopify_stock_queue_form" model="ir.ui.view">
        <field name="name">shopify.stock.queue.form</field>
        <field name="model">shopify.stock.queue</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group>
                            <field name="product_id"/>
                            <field name="binding_id"/>
                            <field name="new_quantity"/>
                        </group>
                        <group>
                            <field name="state"/>
                            <field name="create_date"/>
                        </group>
                    </group>
                    <group string="Error Details"
                           invisible="state != 'error'">
                        <field name="error_message" nolabel="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_shopify_stock_queue" model="ir.actions.act_window">
        <field name="name">Shopify Stock Sync Queue</field>
        <field name="res_model">shopify.stock.queue</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('state', '!=', 'done')]</field>
        <field name="context">{'search_default_filter_pending': 1}</field>
    </record>

    <menuitem
        id="menu_shopify_stock_queue"
        name="Stock Sync Queue"
        action="action_shopify_stock_queue"
        parent="stock.menu_stock_inventory_control"
        sequence="51"
    />

</odoo>
